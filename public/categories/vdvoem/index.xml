d0%9c%d1%83%d1%80%d0%b0%d0%ba%d0%b0%d0%bc%d0%b8%20-%e2%80%93%20%d0%9d%d0%be%d1%87%d1%8c.mp3&#34; type=&#34;audio/mpeg&#34;&gt;&#xA;      &lt;/audio&gt;&#xA;&#xA;    &lt;/div&gt;&#xA;&#xA;  &#xA;&#xA;&#xA;&#xA;  &#xA;&#xA;    &#xA;    &#xA;&#xA;    &#xA;    &#xA;&#xA;    &#xA;      &#xA;      &#xA;    &#xA;&#xA;    &lt;div class=&#34;audio-item&#34;&gt;&#xA;&#xA;      &lt;div class=&#34;audio-caption&#34;&gt;&#xA;        &#xA;          &lt;strong&gt;Northern Lite &lt;/strong&gt; —&#xA;        &#xA;         What You Want&#xA;      &lt;/div&gt;&#xA;&#xA;      &lt;audio playsinline controls preload=&#34;metadata&#34;&gt;&#xA;        &lt;source src=&#34;http://localhost:1313/audio/2026-05-21-Tashkent-Dushanbe/Northern%20Lite%20--%20What%20You%20Want.mp3&#34; type=&#34;audio/mpeg&#34;&gt;&#xA;      &lt;/audio&gt;&#xA;&#xA;    &lt;/div&gt;&#xA;&#xA;  &#xA;&#xA;&#xA;&#xA;  &#xA;&#xA;    &#xA;    &#xA;&#xA;    &#xA;    &#xA;&#xA;    &#xA;      &#xA;      &#xA;    &#xA;&#xA;    &lt;div class=&#34;audio-item&#34;&gt;&#xA;&#xA;      &lt;div class=&#34;audio-caption&#34;&gt;&#xA;        &#xA;          &lt;strong&gt;Shakra &lt;/strong&gt; —&#xA;        &#xA;         House of Rock&#xA;      &lt;/div&gt;&#xA;&#xA;      &lt;audio playsinline controls preload=&#34;metadata&#34;&gt;&#xA;        &lt;source src=&#34;http://localhost:1313/audio/2026-05-21-Tashkent-Dushanbe/Shakra%20--%20House%20of%20Rock.mp3&#34; type=&#34;audio/mpeg&#34;&gt;&#xA;      &lt;/audio&gt;&#xA;&#xA;    &lt;/div&gt;&#xA;&#xA;  &#xA;&#xA;&#xA;&#xA;  &#xA;&#xA;    &#xA;    &#xA;&#xA;    &#xA;    &#xA;&#xA;    &#xA;      &#xA;      &#xA;    &#xA;&#xA;    &lt;div class=&#34;audio-item&#34;&gt;&#xA;&#xA;      &lt;div class=&#34;audio-caption&#34;&gt;&#xA;        &#xA;          &lt;strong&gt;Wolfpakk &lt;/strong&gt; —&#xA;        &#xA;         I&amp;#39;m Onto You&#xA;      &lt;/div&gt;&#xA;&#xA;      &lt;audio playsinline controls preload=&#34;metadata&#34;&gt;&#xA;        &lt;source src=&#34;http://localhost:1313/audio/2026-05-21-Tashkent-Dushanbe/Wolfpakk%20--%20I%27m%20Onto%20You.mp3&#34; type=&#34;audio/mpeg&#34;&gt;&#xA;      &lt;/audio&gt;&#xA;&#xA;    &lt;/div&gt;&#xA;&#xA;  &#xA;&#xA;&#xA;&#xA;  &#xA;&#xA;    &#xA;    &#xA;&#xA;    &#xA;    &#xA;&#xA;    &#xA;      &#xA;      &#xA;    &#xA;&#xA;    &lt;div class=&#34;audio-item&#34;&gt;&#xA;&#xA;      &lt;div class=&#34;audio-caption&#34;&gt;&#xA;        &#xA;          &lt;strong&gt;Последние варвары &lt;/strong&gt; —&#xA;        &#xA;         За горизонтом&#xA;      &lt;/div&gt;&#xA;&#xA;      &lt;audio playsinline controls preload=&#34;metadata&#34;&gt;&#xA;        &lt;source src=&#34;http://localhost:1313/audio/2026-05-21-Tashkent-Dushanbe/%d0%9f%d0%be%d1%81%d0%bb%d0%b5%d0%b4%d0%bd%d0%b8%d0%b5%20%d0%b2%d0%b0%d1%80%d0%b2%d0%b0%d1%80%d1%8b%20--%20%d0%97%d0%b0%20%d0%b3%d0%be%d1%80%d0%b8%d0%b7%d0%be%d0%bd%d1%82%d0%be%d0%bc.mp3&#34; type=&#34;audio/mpeg&#34;&gt;&#xA;      &lt;/audio&gt;&#xA;&#xA;    &lt;/div&gt;&#xA;&#xA;  &#xA;&#xA;&#xA;&#xA;  &#xA;&#xA;    &#xA;    &#xA;&#xA;    &#xA;    &#xA;&#xA;    &#xA;      &#xA;      &#xA;    &#xA;&#xA;    &lt;div class=&#34;audio-item&#34;&gt;&#xA;&#xA;      &lt;div class=&#34;audio-caption&#34;&gt;&#xA;        &#xA;          &lt;strong&gt;Последние варвары &lt;/strong&gt; —&#xA;        &#xA;         Полные баки любви&#xA;      &lt;/div&gt;&#xA;&#xA;      &lt;audio playsinline controls preload=&#34;metadata&#34;&gt;&#xA;        &lt;source src=&#34;http://localhost:1313/audio/2026-05-21-Tashkent-Dushanbe/%d0%9f%d0%be%d1%81%d0%bb%d0%b5%d0%b4%d0%bd%d0%b8%d0%b5%20%d0%b2%d0%b0%d1%80%d0%b2%d0%b0%d1%80%d1%8b%20--%20%d0%9f%d0%be%d0%bb%d0%bd%d1%8b%d0%b5%20%d0%b1%d0%b0%d0%ba%d0%b8%20%d0%bb%d1%8e%d0%b1%d0%b2%d0%b8.mp3&#34; type=&#34;audio/mpeg&#34;&gt;&#xA;      &lt;/audio&gt;&#xA;&#xA;    &lt;/div&gt;&#xA;&#xA;  &#xA;&#xA;&#xA;&#xA;  &#xA;&#xA;    &#xA;    &#xA;&#xA;    &#xA;    &#xA;&#xA;    &#xA;      &#xA;      &#xA;    &#xA;&#xA;    &lt;div class=&#34;audio-item&#34;&gt;&#xA;&#xA;      &lt;div class=&#34;audio-caption&#34;&gt;&#xA;        &#xA;          &lt;strong&gt;Театр теней &lt;/strong&gt; —&#xA;        &#xA;         Верь только себе&#xA;      &lt;/div&gt;&#xA;&#xA;      &lt;audio playsinline controls preload=&#34;metadata&#34;&gt;&#xA;        &lt;source src=&#34;http://localhost:1313/audio/2026-05-21-Tashkent-Dushanbe/%d0%a2%d0%b5%d0%b0%d1%82%d1%80%20%d1%82%d0%b5%d0%bd%d0%b5%d0%b9%20--%20%d0%92%d0%b5%d1%80%d1%8c%20%d1%82%d0%be%d0%bb%d1%8c%d0%ba%d0%be%20%d1%81%d0%b5%d0%b1%d0%b5.mp3&#34; type=&#34;audio/mpeg&#34;&gt;&#xA;      &lt;/audio&gt;&#xA;&#xA;    &lt;/div&gt;&#xA;&#xA;  &#xA;&#xA;&#xA;&#xA;&lt;/div&gt;&#xA;&#xA;&lt;/details&gt;&#xA;&#xA;&lt;h2 id=&#34;часть-i-едем&#34;&gt;Часть I. Едем!&lt;/h2&gt;&#xA;&lt;p&gt;Люблю утро — раннее утро, когда город ещё спит и улицы пустынны. Трогаемся в одиночестве со стоп-линии одной из главных улиц Ташкента. Уже привычный маршрут — на заправку «Лукойл», где, из‑за наличия нормального бензина октанового числа 95, встречаются все мотоциклисты. В зеркалах заднего вида мелькает люстра от Жениного «Вулкана», слышу приятный бас его выхлопа рядом. Кофе, полные баки, ловим настрой — дорога мне знакома, я совсем недавно вернулся из Душанбе: ездил туда просто проветрить голову и встретить свой день рождения в дороге. Но каждый раз выезд в красивейший Таджикистан меня приподнимает и наполняет изнутри какой‑то детской беспричинной радостью. Особенно в тему звучат слова песни: «…лицемеров не слушай — в заточенье счастья не найти. Нам же надо немного — миновать города. Это наша дорога и сегодня как всегда…»&lt;/p&gt;</description>
