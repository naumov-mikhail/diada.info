pe=&#34;audio/mpeg&#34;&gt;&#xA;      &lt;/audio&gt;&#xA;&#xA;    &lt;/div&gt;&#xA;&#xA;  &#xA;&#xA;&#xA;&#xA;  &#xA;&#xA;    &#xA;    &#xA;&#xA;    &#xA;    &#xA;&#xA;    &#xA;      &#xA;      &#xA;    &#xA;&#xA;    &lt;div class=&#34;audio-item&#34;&gt;&#xA;&#xA;      &lt;div class=&#34;audio-caption&#34;&gt;&#xA;        &#xA;          &lt;strong&gt;Tom Cochrane &lt;/strong&gt; —&#xA;        &#xA;         Life Is A Highway&#xA;      &lt;/div&gt;&#xA;&#xA;      &lt;audio playsinline controls preload=&#34;metadata&#34;&gt;&#xA;        &lt;source src=&#34;http://localhost:1313/audio/2023-09-19-Tyumen-Cholpon-Ata/Tom%20Cochrane%20--%20Life%20Is%20A%20Highway.mp3&#34; type=&#34;audio/mpeg&#34;&gt;&#xA;      &lt;/audio&gt;&#xA;&#xA;    &lt;/div&gt;&#xA;&#xA;  &#xA;&#xA;&#xA;&#xA;  &#xA;&#xA;    &#xA;    &#xA;&#xA;    &#xA;    &#xA;&#xA;    &#xA;&#xA;    &lt;div class=&#34;audio-item&#34;&gt;&#xA;&#xA;      &lt;div class=&#34;audio-caption&#34;&gt;&#xA;        &#xA;        Аэронавтика - Дороги&#xA;      &lt;/div&gt;&#xA;&#xA;      &lt;audio playsinline controls preload=&#34;metadata&#34;&gt;&#xA;        &lt;source src=&#34;http://localhost:1313/audio/2023-09-19-Tyumen-Cholpon-Ata/%d0%90%d1%8d%d1%80%d0%be%d0%bd%d0%b0%d0%b2%d1%82%d0%b8%d0%ba%d0%b0%20-%20%d0%94%d0%be%d1%80%d0%be%d0%b3%d0%b8.mp3&#34; type=&#34;audio/mpeg&#34;&gt;&#xA;      &lt;/audio&gt;&#xA;&#xA;    &lt;/div&gt;&#xA;&#xA;  &#xA;&#xA;&#xA;&#xA;  &#xA;&#xA;    &#xA;    &#xA;&#xA;    &#xA;    &#xA;&#xA;    &#xA;      &#xA;      &#xA;    &#xA;&#xA;    &lt;div class=&#34;audio-item&#34;&gt;&#xA;&#xA;      &lt;div class=&#34;audio-caption&#34;&gt;&#xA;        &#xA;          &lt;strong&gt;Дом ветров &lt;/strong&gt; —&#xA;        &#xA;         Узоры дорог&#xA;      &lt;/div&gt;&#xA;&#xA;      &lt;audio playsinline controls preload=&#34;metadata&#34;&gt;&#xA;        &lt;source src=&#34;http://localhost:1313/audio/2023-09-19-Tyumen-Cholpon-Ata/%d0%94%d0%be%d0%bc%20%d0%b2%d0%b5%d1%82%d1%80%d0%be%d0%b2%20--%20%d0%a3%d0%b7%d0%be%d1%80%d1%8b%20%d0%b4%d0%be%d1%80%d0%be%d0%b3.mp3&#34; type=&#34;audio/mpeg&#34;&gt;&#xA;      &lt;/audio&gt;&#xA;&#xA;    &lt;/div&gt;&#xA;&#xA;  &#xA;&#xA;&#xA;&#xA;  &#xA;&#xA;    &#xA;    &#xA;&#xA;    &#xA;    &#xA;&#xA;    &#xA;      &#xA;      &#xA;    &#xA;&#xA;    &lt;div class=&#34;audio-item&#34;&gt;&#xA;&#xA;      &lt;div class=&#34;audio-caption&#34;&gt;&#xA;        &#xA;          &lt;strong&gt;Каменные &lt;/strong&gt; —&#xA;        &#xA;         За стеной&#xA;      &lt;/div&gt;&#xA;&#xA;      &lt;audio playsinline controls preload=&#34;metadata&#34;&gt;&#xA;        &lt;source src=&#34;http://localhost:1313/audio/2023-09-19-Tyumen-Cholpon-Ata/%d0%9a%d0%b0%d0%bc%d0%b5%d0%bd%d0%bd%d1%8b%d0%b5%20--%20%d0%97%d0%b0%20%d1%81%d1%82%d0%b5%d0%bd%d0%be%d0%b9.mp3&#34; type=&#34;audio/mpeg&#34;&gt;&#xA;      &lt;/audio&gt;&#xA;&#xA;    &lt;/div&gt;&#xA;&#xA;  &#xA;&#xA;&#xA;&#xA;  &#xA;&#xA;    &#xA;    &#xA;&#xA;    &#xA;    &#xA;&#xA;    &#xA;      &#xA;      &#xA;    &#xA;&#xA;    &lt;div class=&#34;audio-item&#34;&gt;&#xA;&#xA;      &lt;div class=&#34;audio-caption&#34;&gt;&#xA;        &#xA;          &lt;strong&gt;Каменные &lt;/strong&gt; —&#xA;        &#xA;         Свобода&#xA;      &lt;/div&gt;&#xA;&#xA;      &lt;audio playsinline controls preload=&#34;metadata&#34;&gt;&#xA;        &lt;source src=&#34;http://localhost:1313/audio/2023-09-19-Tyumen-Cholpon-Ata/%d0%9a%d0%b0%d0%bc%d0%b5%d0%bd%d0%bd%d1%8b%d0%b5%20--%20%d0%a1%d0%b2%d0%be%d0%b1%d0%be%d0%b4%d0%b0.mp3&#34; type=&#34;audio/mpeg&#34;&gt;&#xA;      &lt;/audio&gt;&#xA;&#xA;    &lt;/div&gt;&#xA;&#xA;  &#xA;&#xA;&#xA;&#xA;  &#xA;&#xA;    &#xA;    &#xA;&#xA;    &#xA;    &#xA;&#xA;    &#xA;      &#xA;      &#xA;    &#xA;&#xA;    &lt;div class=&#34;audio-item&#34;&gt;&#xA;&#xA;      &lt;div class=&#34;audio-caption&#34;&gt;&#xA;        &#xA;          &lt;strong&gt;Сверный флот &lt;/strong&gt; —&#xA;        &#xA;         Северный слот&#xA;      &lt;/div&gt;&#xA;&#xA;      &lt;audio playsinline controls preload=&#34;metadata&#34;&gt;&#xA;        &lt;source src=&#34;http://localhost:1313/audio/2023-09-19-Tyumen-Cholpon-Ata/%d0%a1%d0%b2%d0%b5%d1%80%d0%bd%d1%8b%d0%b9%20%d1%84%d0%bb%d0%be%d1%82%20--%20%d0%a1%d0%b5%d0%b2%d0%b5%d1%80%d0%bd%d1%8b%d0%b9%20%d1%81%d0%bb%d0%be%d1%82.mp3&#34; type=&#34;audio/mpeg&#34;&gt;&#xA;      &lt;/audio&gt;&#xA;&#xA;    &lt;/div&gt;&#xA;&#xA;  &#xA;&#xA;&#xA;&#xA;&lt;/div&gt;&#xA;&#xA;&lt;/details&gt;&#xA;&#xA;&lt;h2 id=&#34;часть-1-сборы-и-выезд-в-казахстан&#34;&gt;Часть 1. Сборы и выезд в Казахстан&lt;/h2&gt;&#xA;&lt;p&gt;В конце мая 2023 г. я собрался перегнать своим ходом мотоцикл из Тюмени до временного места жительства в Кыргызстане — на озеро Иссык-Куль, в городок Чолпон-Ата. Отсутствие моего железного друга на берегу этого красивейшего озера в этой красивейшей горной стране меня сильно тяготило. Спасался тем, что перечитывал дорожные дневники Криса Скотта в «Книге искателей приключений» и открывал для себя Роберта Фултона и его чудесную «One Man Caravan».&lt;/p&gt;</description>
