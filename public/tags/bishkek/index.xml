  &lt;source src=&#34;http://localhost:1313/audio/2026-05-21-Tashkent-Dushanbe/LASCALA,%20%d0%9c%d1%83%d1%80%d0%b0%d0%ba%d0%b0%d0%bc%d0%b8%20-%e2%80%93%20%d0%9d%d0%be%d1%87%d1%8c.mp3&#34; type=&#34;audio/mpeg&#34;&gt;&#xA;      &lt;/audio&gt;&#xA;&#xA;    &lt;/div&gt;&#xA;&#xA;  &#xA;&#xA;&#xA;&#xA;  &#xA;&#xA;    &#xA;    &#xA;&#xA;    &#xA;    &#xA;&#xA;    &#xA;      &#xA;      &#xA;    &#xA;&#xA;    &lt;div class=&#34;audio-item&#34;&gt;&#xA;&#xA;      &lt;div class=&#34;audio-caption&#34;&gt;&#xA;        &#xA;          &lt;strong&gt;Northern Lite &lt;/strong&gt; —&#xA;        &#xA;         What You Want&#xA;      &lt;/div&gt;&#xA;&#xA;      &lt;audio playsinline controls preload=&#34;metadata&#34;&gt;&#xA;        &lt;source src=&#34;http://localhost:1313/audio/2026-05-21-Tashkent-Dushanbe/Northern%20Lite%20--%20What%20You%20Want.mp3&#34; type=&#34;audio/mpeg&#34;&gt;&#xA;      &lt;/audio&gt;&#xA;&#xA;    &lt;/div&gt;&#xA;&#xA;  &#xA;&#xA;&#xA;&#xA;  &#xA;&#xA;    &#xA;    &#xA;&#xA;    &#xA;    &#xA;&#xA;    &#xA;      &#xA;      &#xA;    &#xA;&#xA;    &lt;div class=&#34;audio-item&#34;&gt;&#xA;&#xA;      &lt;div class=&#34;audio-caption&#34;&gt;&#xA;        &#xA;          &lt;strong&gt;Shakra &lt;/strong&gt; —&#xA;        &#xA;         House of Rock&#xA;      &lt;/div&gt;&#xA;&#xA;      &lt;audio playsinline controls preload=&#34;metadata&#34;&gt;&#xA;        &lt;source src=&#34;http://localhost:1313/audio/2026-05-21-Tashkent-Dushanbe/Shakra%20--%20House%20of%20Rock.mp3&#34; type=&#34;audio/mpeg&#34;&gt;&#xA;      &lt;/audio&gt;&#xA;&#xA;    &lt;/div&gt;&#xA;&#xA;  &#xA;&#xA;&#xA;&#xA;  &#xA;&#xA;    &#xA;    &#xA;&#xA;    &#xA;    &#xA;&#xA;    &#xA;      &#xA;      &#xA;    &#xA;&#xA;    &lt;div class=&#34;audio-item&#34;&gt;&#xA;&#xA;      &lt;div class=&#34;audio-caption&#34;&gt;&#xA;        &#xA;          &lt;strong&gt;Wolfpakk &lt;/strong&gt; —&#xA;        &#xA;         I&amp;#39;m Onto You&#xA;      &lt;/div&gt;&#xA;&#xA;      &lt;audio playsinline controls preload=&#34;metadata&#34;&gt;&#xA;        &lt;source src=&#34;http://localhost:1313/audio/2026-05-21-Tashkent-Dushanbe/Wolfpakk%20--%20I%27m%20Onto%20You.mp3&#34; type=&#34;audio/mpeg&#34;&gt;&#xA;      &lt;/audio&gt;&#xA;&#xA;    &lt;/div&gt;&#xA;&#xA;  &#xA;&#xA;&#xA;&#xA;  &#xA;&#xA;    &#xA;    &#xA;&#xA;    &#xA;    &#xA;&#xA;    &#xA;      &#xA;      &#xA;    &#xA;&#xA;    &lt;div class=&#34;audio-item&#34;&gt;&#xA;&#xA;      &lt;div class=&#34;audio-caption&#34;&gt;&#xA;        &#xA;          &lt;strong&gt;Последние варвары &lt;/strong&gt; —&#xA;        &#xA;         За горизонтом&#xA;      &lt;/div&gt;&#xA;&#xA;      &lt;audio playsinline controls preload=&#34;metadata&#34;&gt;&#xA;        &lt;source src=&#34;http://localhost:1313/audio/2026-05-21-Tashkent-Dushanbe/%d0%9f%d0%be%d1%81%d0%bb%d0%b5%d0%b4%d0%bd%d0%b8%d0%b5%20%d0%b2%d0%b0%d1%80%d0%b2%d0%b0%d1%80%d1%8b%20--%20%d0%97%d0%b0%20%d0%b3%d0%be%d1%80%d0%b8%d0%b7%d0%be%d0%bd%d1%82%d0%be%d0%bc.mp3&#34; type=&#34;audio/mpeg&#34;&gt;&#xA;      &lt;/audio&gt;&#xA;&#xA;    &lt;/div&gt;&#xA;&#xA;  &#xA;&#xA;&#xA;&#xA;  &#xA;&#xA;    &#xA;    &#xA;&#xA;    &#xA;    &#xA;&#xA;    &#xA;      &#xA;      &#xA;    &#xA;&#xA;    &lt;div class=&#34;audio-item&#34;&gt;&#xA;&#xA;      &lt;div class=&#34;audio-caption&#34;&gt;&#xA;        &#xA;          &lt;strong&gt;Последние варвары &lt;/strong&gt; —&#xA;        &#xA;         Полные баки любви&#xA;      &lt;/div&gt;&#xA;&#xA;      &lt;audio playsinline controls preload=&#34;metadata&#34;&gt;&#xA;        &lt;source src=&#34;http://localhost:1313/audio/2026-05-21-Tashkent-Dushanbe/%d0%9f%d0%be%d1%81%d0%bb%d0%b5%d0%b4%d0%bd%d0%b8%d0%b5%20%d0%b2%d0%b0%d1%80%d0%b2%d0%b0%d1%80%d1%8b%20--%20%d0%9f%d0%be%d0%bb%d0%bd%d1%8b%d0%b5%20%d0%b1%d0%b0%d0%ba%d0%b8%20%d0%bb%d1%8e%d0%b1%d0%b2%d0%b8.mp3&#34; type=&#34;audio/mpeg&#34;&gt;&#xA;      &lt;/audio&gt;&#xA;&#xA;    &lt;/div&gt;&#xA;&#xA;  &#xA;&#xA;&#xA;&#xA;  &#xA;&#xA;    &#xA;    &#xA;&#xA;    &#xA;    &#xA;&#xA;    &#xA;      &#xA;      &#xA;    &#xA;&#xA;    &lt;div class=&#34;audio-item&#34;&gt;&#xA;&#xA;      &lt;div class=&#34;audio-caption&#34;&gt;&#xA;        &#xA;          &lt;strong&gt;Театр теней &lt;/strong&gt; —&#xA;        &#xA;         Верь только себе&#xA;      &lt;/div&gt;&#xA;&#xA;      &lt;audio playsinline controls preload=&#34;metadata&#34;&gt;&#xA;        &lt;source src=&#34;http://localhost:1313/audio/2026-05-21-Tashkent-Dushanbe/%d0%a2%d0%b5%d0%b0%d1%82%d1%80%20%d1%82%d0%b5%d0%bd%d0%b5%d0%b9%20--%20%d0%92%d0%b5%d1%80%d1%8c%20%d1%82%d0%be%d0%bb%d1%8c%d0%ba%d0%be%20%d1%81%d0%b5%d0%b1%d0%b5.mp3&#34; type=&#34;audio/mpeg&#34;&gt;&#xA;      &lt;/audio&gt;&#xA;&#xA;    &lt;/div&gt;&#xA;&#xA;  &#xA;&#xA;&#xA;&#xA;&lt;/div&gt;&#xA;&#xA;&lt;/details&gt;&#xA;&#xA;&lt;h2 id=&#34;часть-i-авантюра-заворачивайте&#34;&gt;Часть I. Авантюра? Заворачивайте!&lt;/h2&gt;&#xA;&lt;p&gt;В начале мая 2024 года мне очень захотелось проветриться. Я уже выяснил, какое проклятие наложили на меня местные узбекские номерные знаки — просто так, через льготный ввоз проехать на территорию Казахстана, мне — обладателю российского паспорта — не получится. Только через карнет и вот это всё&amp;hellip; Я заехал в посольство Кыргызстана в Ташкенте и душевно пообщался с сотрудником консульского отдела. Он меня уверил — проблем при пересечении границы верхом на мотоцикле с номерами не Таможенного союза не будет. Я на такой уверенности поехал, и пару-тройку раз такая уверенность меня и протаскивала через кордоны. Но в один раз удача закончилась&amp;hellip; но это уже совсем другая история.&lt;/p&gt;</description>
			</item>
			<item>
				<title>Перегон Друга из Тюмени до Иссык-Куля</title>
				<link>http://localhost:1313/posts/2023-09-19-tyumen-cholpon-ata/</link>
				<pubDate>Fri, 19 May 2023 00:00:00 +0000</pubDate><author>mn@diada.info (Mikhail Naumov)</author>
